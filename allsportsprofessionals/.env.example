# Google Apps Script Web App URL (for Google Sheets integration)
# Follow instructions in google-apps-script.js to set up
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# EmailJS Configuration (for email notifications)
# Sign up at https://www.emailjs.com/
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_ID=your_template_id
EMAILJS_PUBLIC_KEY=your_public_key

# Notification email for new inquiries
NOTIFICATION_EMAIL=info@allsportsprofessionals.com

# Site URL for sitemap generation
SITE_URL=https://allsportsprofessionals.com
